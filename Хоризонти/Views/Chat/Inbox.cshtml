@model List<string>

<h2>Потребители, които са ви писали</h2>

@if (!Model.Any())
{
    <p>Няма съобщения.</p>
}
else
{
    foreach (var userId in Model)
    {
        <div>
            <a asp-controller="Chat"
               asp-action="Conversation"
               asp-route-userId="@userId">
                Отвори разговор с @userId
            </a>
        </div>
    }
}
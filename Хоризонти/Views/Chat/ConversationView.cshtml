@model List<Horizons.Data.Models.Message>

@{
    var guideEmail = ViewBag.GuideEmail;
    var userEmail = ViewBag.UserEmail;
    var guideId = ViewBag.GuideId;
    var userId = ViewBag.UserId;
    var currentUser = User.Identity!.Name;
}

<style>

    .chat-container {
        background: #f8f9fa;
        padding: 25px;
        border-radius: 20px;
        min-height: 400px;
    }

    .chat-box {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .message {
        max-width: 420px;
        padding: 12px 18px;
        border-radius: 18px;
    }

    .user-message {
        background: #e4e6eb;
    }

    .guide-message {
        background: #1877f2;
        color: white;
        margin-left: auto;
    }

    .chat-input {
        margin-top: 20px;
        display: flex;
        gap: 10px;
    }

</style>

@if (guideEmail != null)
{
    <h2>💬 Чат с @guideEmail</h2>
}
else if (userEmail != null)
{
    <h2>💬 Чат с @userEmail</h2>
}
else
{
    <h2>💬 Разговор</h2>
}

<div class="chat-container">

    <div class="chat-box" id="chatBox">

        @foreach (var msg in Model)
        {
            bool isMine = msg.Sender.Email == currentUser;

            <div class="message @(isMine ? "guide-message" : "user-message")">

                <div>@msg.Content</div>

                <small>@msg.SentOn.ToLocalTime()</small>

            </div>
        }

    </div>

    <form method="post"
          asp-controller="Chat"
          asp-action="@(guideId != null ? "SendToGuide" : "SendToUser")">

        @if (guideId != null)
        {
            <input type="hidden" name="guideId" value="@guideId" />
        }

        @if (userId != null)
        {
            <input type="hidden" name="userId" value="@userId" />
        }

        <div class="chat-input">

<textarea name="content"
          class="form-control"
          placeholder="Напиши съобщение..."
          required></textarea>

            <button class="btn btn-primary">
                Изпрати
            </button>

        </div>

    </form>

</div>

<script>

    var chatBox = document.getElementById("chatBox");
    chatBox.scrollTop = chatBox.scrollHeight;

</script>
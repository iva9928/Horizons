@model List<Horizons.Data.Models.Message>

<h2>📢 Публични съобщения</h2>

@if (!Model.Any())
{
    <p>Няма съобщения.</p>
}

@foreach (var msg in Model)
{
    <div style="border-bottom:1px solid #ddd; padding:10px; margin-bottom:10px">

        <strong>@msg.Sender.Email</strong>

        <div>@msg.Content</div>

        <small>@msg.SentOn.ToLocalTime()</small>

    </div>
}

@if (User.IsInRole("Guide"))
{
    <form asp-action="SendPublic" method="post">

        <textarea name="content"
              class="form-control"
              rows="3"
              placeholder="Напиши публично съобщение..."
              required></textarea>

        <button class="btn btn-success mt-2">
            Изпрати съобщение
        </button>

    </form>
}
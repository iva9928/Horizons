@model List<Horizons.Data.Models.Message>

<h2>Разговор</h2>

@foreach (var msg in Model)
{
    <div>
        <strong>@msg.Sender.UserName:</strong>
        @msg.Content
        <small>@msg.SentOn</small>
    </div>
}

<form asp-action="SendToGuide" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="guideId" value="@ViewBag.GuideId" />
    <textarea name="content" required></textarea>
    <button type="submit">Изпрати</button>
</form>
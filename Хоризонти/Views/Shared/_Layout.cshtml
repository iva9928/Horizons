@using Microsoft.AspNetCore.Identity
@using Horizons.Data.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="bg">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Horizons</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>

        body {
            background: #f2f7f5;
        }

        nav.navbar {
            background: #247158;
            padding: 12px 20px;
            box-shadow: 0 3px 8px rgba(0,0,0,0.15);
        }

        .navbar-brand,
        .nav-link {
            color: white !important;
            font-weight: 500;
        }

        .btn-logout {
            background: #ffcc00;
            border: none;
            padding: 6px 16px;
            border-radius: 8px;
            font-weight: 600;
        }

        .btn-add-destination {
            background: #2ecc71;
            border: none;
            padding: 6px 14px;
            border-radius: 8px;
            font-weight: 600;
            margin-left: 10px;
        }

            .btn-add-destination:hover {
                background: #27ae60;
            }

    </style>

</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark">

            <a class="navbar-brand"
               asp-controller="Home"
               asp-action="Index">
                Horizons
            </a>

            <ul class="navbar-nav me-auto">

                @if (User.IsInRole("Admin"))
                {

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Destination"
                           asp-action="Index">
                            Дестинации
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Destination"
                           asp-action="Favorites">
                            ❤️ Любими
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Destination"
                           asp-action="Seasons">
                            🌤 Сезонност
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Guide"
                           asp-action="Index">
                            🧭 Тур гайдове
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link btn-add-destination"
                           asp-controller="Destination"
                           asp-action="Add">
                            ➕ Добави дестинация
                        </a>
                    </li>

                }

                else if (User.IsInRole("Guide"))
                {

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Guide"
                           asp-action="MyProfile">
                            🧭 Моят профил
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Chat"
                           asp-action="GuideBoard">
                            📩 Съобщения
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Chat"
                           asp-action="PublicChat">
                            📢 Публични съобщения
                        </a>
                    </li>

                }

                else
                {

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Destination"
                           asp-action="Index">
                            Дестинации
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Destination"
                           asp-action="Favorites">
                            ❤️ Любими
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Destination"
                           asp-action="Seasons">
                            🌤 Сезонност
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Guide"
                           asp-action="Index">
                            🧭 Тур гайдове
                        </a>
                    </li>

                    <!-- ТОВА Е НОВОТО -->

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Chat"
                           asp-action="ChatWithGuide"
                           asp-route-guideId="22222222-2222-2222-2222-222222222222">
                            📩 Съобщения
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Chat"
                           asp-action="PublicChat">
                            📢 Публични съобщения
                        </a>
                    </li>

                }

            </ul>

            <ul class="navbar-nav ms-auto">

                @if (SignInManager.IsSignedIn(User))
                {

                    <li class="nav-item">
                        <span class="nav-link">
                            👤 @User.Identity!.Name
                        </span>
                    </li>

                    <li class="nav-item">

                        <form method="post"
                              asp-area="Identity"
                              asp-page="/Account/Logout">

                            <button class="btn btn-logout">
                                Изход
                            </button>

                        </form>

                    </li>

                }
                else
                {

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Identity"
                           asp-page="/Account/Login">
                            Вход
                        </a>
                    </li>

                }

            </ul>

        </nav>

    </header>

    <div class="container mt-4">

        @RenderBody()

    </div>

    <footer class="text-center text-muted mt-5 py-3">

        © @DateTime.Now.Year Horizons

    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
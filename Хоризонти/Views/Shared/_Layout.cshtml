@using Microsoft.AspNetCore.Identity
@using Horizons.Data.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="bg">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Horizons</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>

        body {
            background: #f2f7f5;
        }

        nav.navbar {
            background: #247158;
            padding: 12px 20px;
            box-shadow: 0 3px 8px rgba(0,0,0,0.15);
        }

        .navbar-brand, .nav-link {
            color: white !important;
            font-weight: 500;
        }

        .btn-logout {
            background: #ffcc00;
            border: none;
            padding: 6px 16px;
            border-radius: 8px;
            font-weight: 600;
        }

        #ai-chat-button {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 60px;
            height: 60px;
            background: #247158;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 50%;
            cursor: pointer;
            font-size: 28px;
        }

    </style>

</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                Horizons
            </a>

            <ul class="navbar-nav me-auto">

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Destination" asp-action="Index">
                        Дестинации
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Destination" asp-action="Favorites">
                        ❤️ Любими
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Destination" asp-action="Seasons">
                        🌤 Сезонност
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Guide" asp-action="Index">
                        🧭 Тур гайдове
                    </a>
                </li>

            </ul>

            <ul class="navbar-nav ms-auto">

                @if (SignInManager.IsSignedIn(User))
                {

                    <li class="nav-item">
                        <span class="nav-link">
                            👤 @User.Identity!.Name
                        </span>
                    </li>

                    <li class="nav-item">

                        <form method="post"
                              asp-area="Identity"
                              asp-page="/Account/Logout">

                            <button class="btn btn-logout">
                                Изход
                            </button>

                        </form>

                    </li>

                }
                else
                {

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Identity"
                           asp-page="/Account/Login">
                            Вход
                        </a>
                    </li>

                }

            </ul>

        </nav>

    </header>

    <div class="container mt-4">

        @RenderBody()

    </div>

    <footer class="text-center text-muted mt-5 py-3">

        © @DateTime.Now.Year Horizons

    </footer>

    <div id="ai-chat-button">🤖</div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Тур гайдове";
}

<style>

    .page-title {
        font-size: 38px;
        font-weight: 700;
        margin-top: 20px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .guides-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(260px,1fr));
        gap: 30px;
    }

    .guide-card {
        background: white;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(0,0,0,0.12);
        transition: 0.35s;
        position: relative;
    }

        .guide-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 25px 50px rgba(0,0,0,0.18);
        }

    .guide-image-wrapper {
        height: 300px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg,#eef5f3,#ffffff);
        padding: 15px;
    }

    .guide-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 16px;
    }

    .guide-body {
        padding: 22px;
    }

    .guide-email {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .guide-bio {
        font-size: 14px;
        color: #6c757d;
        margin-bottom: 18px;
    }

    .profile-btn {
        background: linear-gradient(135deg,#2e9e73,#1e6f52);
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 14px;
        font-weight: 600;
        transition: 0.25s;
        display: inline-block;
        text-decoration: none;
    }

        .profile-btn:hover {
            background: #247158;
            transform: scale(1.05);
        }

</style>

<h1 class="page-title">🧭 Тур гайдове</h1>

<div class="guides-grid">

    @foreach (var guide in Model)
    {

        <div class="guide-card">

            <div class="guide-image-wrapper">

                @if (!string.IsNullOrEmpty(guide.ProfileImageUrl))
                {
                    <img src="@guide.ProfileImageUrl" class="guide-img" />
                }
                else
                {

                    <img src="/images/default-guide.jpg" class="guide-img" />
                }

            </div>

            <div class="guide-body">

                <div class="guide-email">
                    @guide.Email
                </div>

                <div class="guide-bio">
                    @guide.Bio
                </div>

                <a asp-controller="Guide"
                   asp-action="Profile"
                   asp-route-id="@guide.Id"
                   class="profile-btn">

                    Виж профил

                </a>

            </div>

        </div>

    }

</div>

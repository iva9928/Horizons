@using Horizons.Data.Models
@model ApplicationUser

@{
    ViewData["Title"] = "Guide Profile";
}

<!DOCTYPE html>
<html lang="bg">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Guide Profile</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>

        body {
            background: #f2f7f5;
            font-family: Segoe UI;
        }

        .profile-card {
            max-width: 900px;
            margin: 80px auto;
            background: white;
            border-radius: 25px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
            padding: 40px;
            display: flex;
            gap: 40px;
            align-items: center;
        }

        .profile-img {
            width: 260px;
            height: 320px;
            object-fit: cover;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .profile-info {
            flex: 1;
        }

        .profile-title {
            font-size: 34px;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .profile-email {
            font-size: 18px;
            margin-bottom: 15px;
        }

        .profile-bio {
            font-size: 16px;
            color: #6c757d;
            margin-bottom: 25px;
        }

    </style>

</head>

<body>

    <div class="profile-card">

        <img src="@(string.IsNullOrEmpty(Model.ProfileImageUrl)
             ? "/images/default-guide.jpg"
             : Model.ProfileImageUrl)"
             class="profile-img" />

        <div class="profile-info">

            <div class="profile-title">
                Guide Profile
            </div>

            <div class="profile-email">
                <b>Email:</b> @Model.Email
            </div>

            <div class="profile-bio">
                <b>Bio:</b> @Model.Bio
            </div>

        </div>

    </div>

</body>
</html>
@model IEnumerable<DestinationListViewModel>

@{
    ViewData["Title"] = "Любими дестинации";
}

<style>

    .favorite-card {
        background: white;
        border-radius: 18px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        padding: 20px;
        transition: 0.3s;
    }

        .favorite-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.15);
        }

    .destination-img {
        height: 120px;
        object-fit: cover;
        border-radius: 12px;
    }

    .remove-btn {
        border-radius: 12px;
        padding: 8px 16px;
    }

</style>

<h2 class="mb-4">❤️ Любими дестинации</h2>

@if (Model == null || !Model.Any())
{

    <div class="text-center mt-5">

        <h4>Нямате добавени любими дестинации</h4>

        <p class="text-muted">
            Разгледайте и добавете места които харесвате.
        </p>

    </div>
}
else
{

    <div class="row">

        @foreach (var destination in Model)
        {

            <div class="col-md-6 col-lg-4 mb-4">

                <div class="favorite-card">

                    @if (!string.IsNullOrEmpty(destination.ImageUrl))
                    {
                        <img src="@destination.ImageUrl"
                               class="w-100 destination-img" />
                    }
                    else
                    {

                        <img src="~/images/default-image.jpg"
                               class="w-100 destination-img" />
                    }

                    <h5 class="mt-3">
                        @destination.Name
                    </h5>

                   

                    <form asp-controller="Destination"
                          asp-action="RemoveFromFavorites"
                          asp-route-id="@destination.Id"
                          method="post">

                        <button class="btn btn-danger remove-btn">
                            🗑 Премахни
                        </button>

                    </form>

                </div>

            </div>

        }

    </div>

}

<div class="text-center mt-5">

    <a asp-controller="Destination"
       asp-action="Index"
       class="btn btn-success">

        ⬅ Към дестинациите

    </a>

</div>
